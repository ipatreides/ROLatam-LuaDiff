    "wlQ6AQ": {
        "en-US": "[Song Mudoo]\nKids, stay back. Kids, stay back.",
        "pt-BR": "[Song Mudoo]\nCrianças, para trás. Vamos, para trás.",
        "es-ES": "[Song Mudoo]\nNiños, atrás. Vamos, atrás."
    },
    "w1Q6AQ": {
        "en-US": "[Song Mudoo]\nNow, now~ this isn’t something you see every day.\nHey~ you look pretty strong.\nCare to give it a try?",
        "pt-BR": "[Song Mudoo]\nOra, ora~ não é algo que vemos todo dia.\nEi~ você parece forte.\nQuer tentar?",
        "es-ES": "[Song Mudoo]\nVaya, vaya~ no es algo que se ve todos los días.\nOye~ te ves fuerte.\n¿Quieres intentarlo?"
    },
    "xFQ6AQ": {
        "en-US": "Try it.",
        "pt-BR": "Tentar.",
        "es-ES": "Intentar."
    },
    "xVQ6AQ": {
        "en-US": "?????",
        "pt-BR": "?????",
        "es-ES": "?????"
    },
    "xlQ6AQ": {
        "en-US": "Ignore and walk past.",
        "pt-BR": "Ignorar e seguir.",
        "es-ES": "Ignorar y seguir."
    },
    "x1Q6AQ": {
        "en-US": "[Song Mudoo]\nOooh~ I knew my eyes weren’t wrong.\nIf you can lift just this—just this—\nI’ll tell you about a great place.\nAlright, get ready.",
        "pt-BR": "[Song Mudoo]\nOooh~ eu sabia que meus olhos não estavam enganados.\nSe você levantar só isto—só isto—\neu te conto sobre um lugar ótimo.\nCerto, prepare-se.",
        "es-ES": "[Song Mudoo]\nOooh~ sabía que no me equivocaba.\nSi logras levantar solo esto—solo esto—\nte cuento de un buen lugar.\nMuy bien, prepárate."
    },
    "yFQ6AQ": {
        "en-US": "^0000FFSong Mudoo points at a large stone and tells you to lift it.",
        "pt-BR": "^0000FFSong Mudoo aponta para uma pedra enorme e manda você levantá-la.^000000",
        "es-ES": "^0000FFSong Mudoo señala una piedra enorme y te dice que la levantes.^000000"
    },
    "yVQ6AQ": {
        "en-US": "It looks far too heavy for you to lift.^000000",
        "pt-BR": "Parece pesada demais pra você levantar.^000000",
        "es-ES": "Parece demasiado pesada para que la levantes.^000000"
    },
    "ylQ6AQ": {
        "en-US": "[Song Mudoo]\nYou still lack training.\nCome back after you’ve trained more.",
        "pt-BR": "[Song Mudoo]\nVocê ainda precisa treinar mais.\nVolte depois que estiver mais forte.",
        "es-ES": "[Song Mudoo]\nAún te falta entrenamiento.\nVuelve cuando estés más preparado."
    },
    "y1Q6AQ": {
        "en-US": "^0000FFYou lift the stone with ease.^000000",
        "pt-BR": "^0000FFVocê levanta a pedra com facilidade.^000000",
        "es-ES": "^0000FFLevantas la piedra con facilidad.^000000"
    },
    "zFQ6AQ": {
        "en-US": "[Song Mudoo]\nHah-hah, I knew my eyes weren’t wrong.\nNext time we meet,\nI’ll take you somewhere nice.\nSee you again.",
        "pt-BR": "[Song Mudoo]\nHahaha, eu sabia que não estava errado.\nDa próxima vez que nos virmos,\neu te levo a um lugar legal.\nAté mais.",
        "es-ES": "[Song Mudoo]\nJajaja, sabía que tenía razón.\nLa próxima vez que nos veamos,\nte llevo a un buen lugar.\nNos vemos."
    },
    "zVQ6AQ": {
        "en-US": "[Song Mudoo]\nHah-hah~ I knew my eyes weren’t wrong.\nNext time, I’ll take you\nto a nice place.\nSee you again.",
        "pt-BR": "[Song Mudoo]\nHah-hah~ eu sabia que não estava enganado.\nDa próxima vez, eu te levo\npara um bom lugar.\nAté logo.",
        "es-ES": "[Song Mudoo]\nJajaja~ sabía que no me equivocaba.\nLa próxima vez te llevo\na un buen sitio.\nNos vemos."
