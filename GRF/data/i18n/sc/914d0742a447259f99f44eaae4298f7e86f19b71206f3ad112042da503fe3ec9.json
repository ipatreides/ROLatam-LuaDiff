    },
    "blU6AQ": {
        "en-US": "[Song Heeyeon]\nWelcome! This is the Training Hall.\nDo you have any questions?",
        "pt-BR": "[Song Heeyeon]\nBem-vindo! Este é o Salão de Treinamento.\nTem alguma dúvida?",
        "es-ES": "[Song Heeyeon]\n¡Bienvenido! Este es el Salón de Entrenamiento.\n¿Tienes alguna pregunta?"
    },
    "b1U6AQ": {
        "en-US": "Training Hall?",
        "pt-BR": "Salão de Treinamento?",
        "es-ES": "¿Salón de Entrenamiento?"
    },
    "cFU6AQ": {
        "en-US": "What happened to the stone?",
        "pt-BR": "O que aconteceu com a pedra?",
        "es-ES": "¿Qué pasó con la piedra?"
    },
    "cVU6AQ": {
        "en-US": "To the viewing area",
        "pt-BR": "Para a área de observação",
        "es-ES": "A la zona de observación"
    },
    "clU6AQ": {
        "en-US": "Return.",
        "pt-BR": "Voltar.",
        "es-ES": "Regresar."
    },
    "c1U6AQ": {
        "en-US": "Nothing.",
        "pt-BR": "Nada.",
        "es-ES": "Nada."
    },
    "dFU6AQ": {
        "en-US": "[Song Heeyeon]\nThis Training Hall,\nas its name implies,\nis a place for training\nagainst monsters.\nDifferent stages have monsters prepared.",
        "pt-BR": "[Song Heeyeon]\nEste Salão de Treinamento,\ncomo o nome diz,\né um lugar para treinar\ncontra monstros.\nCada estágio tem monstros preparados.",
        "es-ES": "[Song Heeyeon]\nEste Salón de Entrenamiento,\ncomo su nombre indica,\nes un lugar para entrenar\ncontra monstruos.\nCada nivel tiene monstruos preparados."
    },
    "dVU6AQ": {
        "en-US": "[Song Heeyeon]\nA small admission fee applies when entering.",
        "pt-BR": "[Song Heeyeon]\nHá uma pequena taxa de admissão para entrar.",
        "es-ES": "[Song Heeyeon]\nHay una pequeña cuota de entrada."
    },
    "dlU6AQ": {
        "en-US": "[Song Heeyeon]\nYour strength brought you this far.\nYou’ve proven you’re qualified to train here. Take this as a souvenir.\nYou can share it with friends too.",
        "pt-BR": "[Song Heeyeon]\nSua força te trouxe até aqui.\nVocê provou que tem qualificação para treinar aqui. Tome isso como lembrança.\nPode compartilhar com amigos também.",
        "es-ES": "[Song Heeyeon]\nTu fuerza te trajo hasta aquí.\nHas demostrado que estás listo para entrenar aquí. Toma esto como recuerdo.\nTambién puedes compartirlo con tus amigos."
    },
    "d1U6AQ": {
        "en-US": "[Song Heeyeon]\nYes, thank you.\nEnjoy your time.",
        "pt-BR": "[Song Heeyeon]\nSim, obrigada.\nAproveite seu tempo.",
        "es-ES": "[Song Heeyeon]\nSí, gracias.\nDisfruta tu tiempo."
    },
    "eFU6AQ": {
        "en-US": "[Song Heeyeon]\nThank you.\nPlease come again.",
        "pt-BR": "[Song Heeyeon]\nObrigada.\nVolte sempre.",
        "es-ES": "[Song Heeyeon]\nGracias.\nVuelve pronto."
    },
    "eVU6AQ": {
        "en-US": "[Song Heeyeon]\n........\nGoodbye.",
        "pt-BR": "[Song Heeyeon]\n........\nTchau.",
        "es-ES": "[Song Heeyeon]\n........\nAdiós."
    },
