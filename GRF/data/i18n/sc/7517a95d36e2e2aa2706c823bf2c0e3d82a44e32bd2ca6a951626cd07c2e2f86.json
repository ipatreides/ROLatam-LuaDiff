    "S5e8Bw": {
        "en-US": "Rebellion: Ah, that machine over there is completely useless without a modification module.",
        "pt-BR": "Insurgente: Essa máquina só encanta usando os Módulos.",
        "es-ES": "Insurgente: Esta máquina solo encanta usando Módulos."
    },
    "TJe8Bw": {
        "en-US": "[RS26]\nTechnology discovered in the city of the future is now becoming a part of your everyday life. Experience the latest innovation from Regenschirm Robotics with RS26.",
        "pt-BR": "[RS26]\nA tecnologia descoberta na cidade do futuro agora penetra em sua vida diária. Experimente a mais recente criação da Regenschirm: o modelo RS26.",
        "es-ES": "[RS26]\nLa tecnología descubierta en la ciudad del futuro ahora forma parte de tu vida diaria. Prueba la creación más reciente de Regenschirm: el modelo RS26."
    },
    "TZe8Bw": {
        "en-US": "[RS26]\nIf you bring Illusion equipment and enhancement modules, I can upgrade your equipment according to the module you provide.",
        "pt-BR": "[RS26]\nMe traga Módulos para encantar seus equipamentos Ilusión.",
        "es-ES": "[RS26]\nTráeme Módulos para encantar tu equipo Ilusión."
    },
    "Tpe8Bw": {
        "en-US": "[RS26]\nSince the work is done according to standard modules, your equipment will not be destroyed. However, the number of upgrades and other details may vary depending on the module.",
        "pt-BR": "[RS26]\nNão há casos de falha ao encantar, mas o número de encantamentos varia de acordo com o Módulo e com o equipamento.",
        "es-ES": "[RS26]\nNo existe posibilidad de fallo al encantar, pero la cantidad de encantamientos varía según el Módulo y el equipo."
    },
    "T5e8Bw": {
        "en-US": "[RS26]\nThen please come back if you need any help~",
        "pt-BR": "[RS26]\nRetorne quando precisar de ajuda~",
        "es-ES": "[RS26]\nVuelve cuando necesites ayuda~"
    },
