    "KUmeDA": {
        "en-US": "[RS26]\nTechnology discovered in the city of the future now enters your everyday life. Join Regen Schirm Robotics’ latest technology, RS26.",
        "pt-BR": "[RS26]\nA tecnologia descoberta na cidade do futuro agora faz parte do seu dia a dia. Junte-se à mais nova tecnologia da Regen Schirm Robotics, RS26.",
        "es-ES": "[RS26]\nLa tecnología descubierta en la ciudad del futuro ahora se integra en tu vida diaria. Únete a la última tecnología de Regen Schirm Robotics, RS26."
    },
    "KkmeDA": {
        "en-US": "[RS26]\nBring an Illusion Shield and enhancement modules, and we will upgrade your equipment according to the module.",
        "pt-BR": "[RS26]\nTraga um Escudo de Ilusão e módulos de aprimoramento, e melhoraremos seu equipamento de acordo com o módulo.",
        "es-ES": "[RS26]\nTrae un Escudo de Ilusión y módulos de mejora, y reforzaremos tu equipo según el módulo."
    },
    "K0meDA": {
        "en-US": "[RS26]\nSince we work only with standard modules, your equipment will not be destroyed. However, upgrade limits may vary by module.",
        "pt-BR": "[RS26]\nComo trabalhamos com módulos padrão, seu equipamento não será destruído. Porém, os limites de melhoria podem variar conforme o módulo.",
        "es-ES": "[RS26]\nComo trabajamos con módulos estándar, tu equipo no se destruirá. Sin embargo, los límites de mejora pueden variar según el módulo."
